# ===== PRODUCTION CONFIGURATION =====

# Debug Mode
YII_DEBUG=0
YII_ENV=prod

# Database (XAMPP/MAMP default)
DB_HOST=127.0.0.1
DB_PORT=8889
DB_NAME=iform
DB_USER=root
DB_PASSWORD=root

# Application
APP_NAME=iForm
APP_URL=http://iform.local

# Cookie Validation
COOKIE_VALIDATION_KEY=your-secret-key-change-this-in-production

# API Configuration
API_BASE_URL=http://iform.local/api

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls
